# Synapse Cloud Backend — environment configuration.
# Copy to .env and fill in the secrets (the .env file is gitignored).

# ── Supabase (project "synapse") ──────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Secret — copy from Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# ── Daemon auth (custom OAuth 2.0 device-code; HS256 JWT) ─────────────────────
# Generate one: python -c "import secrets; print(secrets.token_urlsafe(48))"
DAEMON_JWT_SECRET=dev-only-change-me
DAEMON_ACCESS_TOKEN_TTL_SECONDS=900
DEVICE_CODE_TTL_SECONDS=600

# ── WebSocket daemon hub ──────────────────────────────────────────────────────
# The hub is served as FastAPI WebSocket routes on the same app/port as REST.
HUB_NODE_ID=local

# ── Agent-orchestration grant signing (ed25519) ───────────────────────────────
# base64 32-byte seed; empty => a deterministic dev key. The daemon's
# SYNAPSE_GRANT_PUBLIC_KEY must be the matching public key. Generate a pair with:
#   python -c "import nacl.signing,base64 as b; sk=nacl.signing.SigningKey.generate(); \
#   print('GRANT_SIGNING_KEY='+b.b64encode(bytes(sk)).decode()); \
#   print('SYNAPSE_GRANT_PUBLIC_KEY='+b.b64encode(bytes(sk.verify_key)).decode())"
GRANT_SIGNING_KEY=

# ── Runtime ───────────────────────────────────────────────────────────────────
# environment: "test" disables outbound side-effects (realtime/storage use fakes)
# Background jobs (heartbeat sweep, rollups, anomaly, notifications) run IN-PROCESS
# via the app lifespan scheduler — no Redis, no separate worker process.
SYNAPSE_ENV=dev
WEB_UI_DIST=
